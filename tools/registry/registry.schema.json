{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spec Registry Schema",
  "type": "object",
  "required": ["version", "lastUpdated", "maintainer", "specs", "namespaces"],
  "properties": {
    "version": { "type": "string" },
    "lastUpdated": { "type": "string", "format": "date" },
    "maintainer": { "type": "string" },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["specId", "title", "version", "status", "owner", "path", "tags", "appliesTo", "lastReviewed"],
        "properties": {
          "specId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*/[a-z][a-z0-9-]*/[a-z0-9-]+$",
            "description": "Namespaced spec ID: namespace/category/pattern-name"
          },
          "title": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "deprecated"]
          },
          "owner": { "type": "string" },
          "path": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "appliesTo": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lastReviewed": { "type": "string", "format": "date" },
          "specType": {
            "type": "string",
            "enum": ["pattern", "template", "page", "token", "component"],
            "description": "Atomic design tier: token, component, pattern (organism), template, page"
          },
          "composedOf": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Spec IDs this template composes — agents must read these before the template"
          },
          "extends": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ],
            "description": "Template spec ID this page spec is derived from"
          },
          "instantiatedBy": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Page spec IDs that implement this template"
          },
          "related": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deprecatedBy": {
            "oneOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "namespaces": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
