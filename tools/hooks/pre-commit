#!/bin/sh
# .git/hooks/pre-commit
# Auto-syncs registry.json and explorer-cache.json when spec files change.
#
# INSTALL:
#   cp spec-framework/tools/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the installer:
#   node spec-framework/tools/hooks/install-hooks.js

SPEC_CHANGED=0

# Check if any spec files are staged
for file in $(git diff --cached --name-only); do
  case "$file" in
    specs/*.spec.md)
      SPEC_CHANGED=1
      break
      ;;
  esac
done

if [ "$SPEC_CHANGED" -eq 1 ]; then
  echo "⟳  Spec files changed — syncing registry..."

  node tools/registry/registry-sync.js --validate
  SYNC_EXIT=$?

  if [ $SYNC_EXIT -ne 0 ]; then
    echo "✗  registry-sync failed. Commit aborted."
    exit 1
  fi

  # Stage the updated registry files
  git add tools/registry/registry.json
  git add tools/registry/explorer-cache.json

  echo "✓  Registry synced and staged"
fi

exit 0
